---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';

const features = [
  {
    icon: 'lucide:shield',
    color: 'text-coren-accent',
    bg: 'bg-coren-accent/10',
    title: 'Local-First by Design',
    desc: 'Every AI request routes through a proxy running on your machine. No logs sent to third parties. No API keys leaving your environment. Works fully offline with Ollama.',
  },
  {
    icon: 'lucide:square-terminal',
    color: 'text-tn-yellow',
    bg: 'bg-tn-yellow/10',
    title: 'Terminal-Native',
    desc: 'Not a sidebar. Not a browser extension. Coren runs inside your terminal session with scroll, mouse support, and a live AI panel that never interrupts your shell.',
  },
  {
    icon: 'lucide:folder-search',
    color: 'text-tn-cyan',
    bg: 'bg-tn-cyan/10',
    title: 'Workspace Awareness',
    desc: 'Drop a context file in your project root. Coren loads it automatically into every session — so the AI knows your stack, conventions, and current goals without re-explaining.',
  },
  {
    icon: 'lucide:layers',
    color: 'text-tn-purple',
    bg: 'bg-tn-purple/10',
    title: 'Four AI Modes',
    desc: 'Switch between Default, Watch, Execute, and Debug depending on what you\'re doing. Each mode adapts to your workflow — from passive observation to active command execution.',
  },
  {
    icon: 'lucide:wand-sparkles',
    color: 'text-tn-orange',
    bg: 'bg-tn-orange/10',
    title: 'Inline Assist',
    desc: 'Ghost-text completions appear as you type. Press Tab to accept. React to command output instantly. No copy-paste. No context switching.',
  },
  {
    icon: 'lucide:git-pull-request-arrow',
    color: 'text-tn-green',
    bg: 'bg-tn-green/10',
    title: 'Code Review in the Terminal',
    desc: 'Review staged diffs file-by-file without leaving your shell. AI flags risky changes, explains context, and helps you resolve conflicts before they hit production.',
  },
];

const modes = [
  {
    icon: '○',
    iconColor: 'text-tn-blue',
    bg: 'bg-tn-blue/10',
    border: 'border-tn-blue/20',
    name: 'Default',
    tag: 'Ask directly',
    desc: 'Open the panel and chat with the active provider in the current workspace. Full conversation context on every request.',
  },
  {
    icon: '◉',
    iconColor: 'text-tn-green',
    bg: 'bg-tn-green/10',
    border: 'border-tn-green/20',
    name: 'Watch',
    tag: 'Observe output',
    desc: 'Detects when a command finishes and waits for your signal. Press Ctrl+E to explain any output — nothing streams automatically.',
  },
  {
    icon: '⚡',
    iconColor: 'text-coren-accent',
    bg: 'bg-coren-accent/10',
    border: 'border-coren-accent/20',
    name: 'Execute',
    tag: 'Suggest next commands',
    desc: 'Set a goal for the current run and pick from AI-suggested commands. Turn a vague objective into a concrete terminal sequence.',
  },
  {
    icon: '🔧',
    iconColor: 'text-tn-orange',
    bg: 'bg-tn-orange/10',
    border: 'border-tn-orange/20',
    name: 'Debug',
    tag: 'Trigger on failure',
    desc: 'Monitors output for errors and failure signals. Press Ctrl+E for instant diagnosis and a fix — no copy-paste, no switching windows.',
  },
];

const themes = [
  {
    name: 'Catppuccin',
    key: 'catppuccin',
    desc: 'Soft pastel palette. Mauve accent on a dark blue-gray base.',
    accent: '#cba6f7',
    bg: '#1e1e2e',
    colors: ['#1e1e2e', '#313244', '#cba6f7', '#89dceb', '#a6e3a1', '#f38ba8'],
  },
  {
    name: 'Dracula',
    key: 'dracula',
    desc: 'High contrast dark theme. Pink accent on a charcoal base.',
    accent: '#ff79c6',
    bg: '#282a36',
    colors: ['#282a36', '#44475a', '#ff79c6', '#8be9fd', '#50fa7b', '#ff5555'],
  },
  {
    name: 'Rosé Pine',
    key: 'rosepine',
    desc: 'Muted, warm tones with a dusty rose accent on deep violet.',
    accent: '#ebbcba',
    bg: '#191724',
    colors: ['#191724', '#26233a', '#ebbcba', '#9ccfd8', '#31748f', '#eb6f92'],
  },
  {
    name: 'Tokyo Night',
    key: 'tokyonight',
    desc: 'Cool navy base with a vivid blue accent. City lights at night.',
    accent: '#7aa2f7',
    bg: '#24283b',
    colors: ['#24283b', '#414868', '#7aa2f7', '#7dcfff', '#9ece6a', '#f7768e'],
  },
];

const providers = ['ollama', 'deepseek', 'openai', 'anthropic', 'gemini', 'groq', 'custom'];

const comparisonRows = [
  { feature: 'Runs locally',                 coren: '✓', cloud: '✗' },
  { feature: 'Code stays on device',         coren: '✓', cloud: '✗' },
  { feature: 'Works with Ollama',            coren: '✓', cloud: '✗' },
  { feature: 'Per-project workspace context',coren: '✓', cloud: '✗' },
  { feature: 'No vendor lock-in',            coren: '✓', cloud: '✗' },
  { feature: 'Terminal-native shell',        coren: '✓', cloud: '✗' },
  { feature: 'Air-gap compatible',           coren: '✓', cloud: '✗' },
  { feature: '7+ provider presets',          coren: '✓', cloud: 'Limited' },
  { feature: 'Free core tier',               coren: '✓', cloud: 'Partial' },
  { feature: 'Starting price',               coren: 'Free', cloud: '$15–$30 / mo' },
];

const trustPills = [
  'Local-first',
  'Ollama compatible',
  'OpenAI-compatible API',
  'Linux-native',
  'Free core forever',
  '7+ provider presets',
];
---

<Layout
  title="Coren — Local AI Terminal for Developers"
  description="Coren is a local-first AI terminal. Run AI models on your machine, keep workspace context per project, and ship faster — without sending a single line of code to the cloud."
>
  <!-- ─── HERO ─────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden px-6">
    <div class="absolute top-0 left-1/4 h-[560px] w-[560px] rounded-full bg-coren-accent/[0.07] blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 right-1/4 h-[440px] w-[440px] rounded-full bg-tn-cyan/[0.04] blur-3xl pointer-events-none"></div>

    <div class="mx-auto grid max-w-6xl items-center gap-12 py-16 md:grid-cols-2 md:py-28">
      <div class="reveal">
        <p class="mb-5 text-xs font-bold uppercase tracking-[0.2em] text-coren-accent">Local-first AI terminal</p>
        <h1 class="mb-6 text-4xl font-bold leading-tight tracking-tight text-tn-text sm:text-5xl md:text-6xl">
          Your code never<br />
          <span class="gradient-text">leaves your machine.</span>
        </h1>
        <p class="mb-8 max-w-xl text-lg leading-relaxed text-tn-subtext">
          Coren brings local AI directly into your terminal workflow. Run models on your machine, keep context per project, and ship faster — without sending a single line to the cloud.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#install" class="btn-primary">
            <Icon name="lucide:download" class="h-4 w-4" />
            Install Coren — it's free
          </a>
          <a href={`${import.meta.env.BASE_URL}docs`} class="btn-secondary">
            <Icon name="lucide:book-open" class="h-4 w-4" />
            Read the docs
          </a>
        </div>
        <p class="mt-6 text-xs text-tn-muted">
          Linux · Supports Ollama, DeepSeek, OpenAI, Anthropic and more · macOS coming soon
        </p>
      </div>

      <!-- Terminal demo -->
      <div class="hidden md:block reveal reveal-delay-2">
        <div class="terminal-window shadow-2xl shadow-black/50">
          <div class="terminal-chrome">
            <span class="h-3 w-3 rounded-full bg-tn-red/80"></span>
            <span class="h-3 w-3 rounded-full bg-tn-yellow/80"></span>
            <span class="h-3 w-3 rounded-full bg-tn-green/80"></span>
            <span class="ml-auto text-xs text-tn-comment">~/projects/api-service</span>
          </div>
          <div class="border-b border-white/[0.05] bg-tn-storm/60 px-3 py-1.5 text-xs text-tn-comment">
            <span class="text-coren-accent">●</span> workspace loaded · mode: watch · provider: ollama
          </div>
          <div class="space-y-1 p-4 text-sm font-mono">
            <div><span class="text-tn-green">❯</span> <span class="text-tn-text">make deploy</span></div>
            <div class="pl-2 text-tn-comment">building image...</div>
            <div class="pl-2 text-tn-red">Error: connection refused on :5432</div>
            <div class="pl-2 text-tn-comment">exit code 1</div>
          </div>
          <div class="border-t border-white/[0.08]">
            <div class="flex items-center justify-between border-b border-white/[0.05] px-4 py-2 text-xs">
              <span class="font-bold text-coren-accent">✦ coren</span>
              <span class="text-tn-comment">local · ollama · gemma4:latest</span>
            </div>
            <div class="space-y-1.5 bg-tn-night/50 p-4 text-xs font-mono">
              <p class="text-tn-subtext">PostgreSQL isn't running. The deploy fails at the DB connection step.</p>
              <p class="text-tn-subtext mt-2">Try:</p>
              <p class="pl-2 text-tn-green">sudo systemctl start postgresql</p>
              <p class="pl-2 text-tn-green">make deploy</p>
              <p class="mt-2 text-tn-muted text-[10px]">Ctrl+E to run suggestion · Tab to accept inline</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── TRUST BAR ──────────────────────────────────────────────── -->
  <section class="border-y border-white/[0.06] bg-tn-night/30 px-6 py-6">
    <div class="mx-auto max-w-6xl">
      <p class="mb-5 text-center text-xs uppercase tracking-[0.2em] text-tn-muted">
        Built for engineers who take their environment seriously
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        {trustPills.map((pill) => (
          <span class="rounded-full border border-white/[0.08] bg-white/[0.02] px-4 py-1.5 text-xs text-tn-subtext">
            {pill}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── PAIN → SOLUTION ────────────────────────────────────────── -->
  <section class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16 text-center reveal">
        <h2 class="section-title">
          You shouldn't have to choose<br class="hidden sm:block" />
          between AI and privacy.
        </h2>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        <div class="reveal reveal-delay-1 rounded-xl border border-white/[0.07] bg-white/[0.02] p-6">
          <div class="mb-4 flex items-center gap-3">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-tn-red/10">
              <Icon name="lucide:cloud-off" class="h-4 w-4 text-tn-red" />
            </div>
          </div>
          <p class="mb-3 text-sm text-tn-comment">
            Cloud AI terminals send your code, prompts, and infra details to external servers on every request.
          </p>
          <div class="border-t border-white/[0.06] pt-3 flex items-start gap-2">
            <Icon name="lucide:check" class="h-4 w-4 text-coren-accent mt-0.5 shrink-0" />
            <p class="text-sm text-tn-text">Coren routes every request through a local proxy. Your data never leaves your machine.</p>
          </div>
        </div>

        <div class="reveal reveal-delay-2 rounded-xl border border-white/[0.07] bg-white/[0.02] p-6">
          <div class="mb-4 flex items-center gap-3">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-tn-red/10">
              <Icon name="lucide:arrow-left-right" class="h-4 w-4 text-tn-red" />
            </div>
          </div>
          <p class="mb-3 text-sm text-tn-comment">
            Most AI tools break your flow. You copy output, switch to a browser tab, paste it in, copy the answer back.
          </p>
          <div class="border-t border-white/[0.06] pt-3 flex items-start gap-2">
            <Icon name="lucide:check" class="h-4 w-4 text-coren-accent mt-0.5 shrink-0" />
            <p class="text-sm text-tn-text">Coren lives inside your terminal. AI panel, inline suggestions, and review — no context switching.</p>
          </div>
        </div>

        <div class="reveal reveal-delay-3 rounded-xl border border-white/[0.07] bg-white/[0.02] p-6">
          <div class="mb-4 flex items-center gap-3">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-tn-red/10">
              <Icon name="lucide:help-circle" class="h-4 w-4 text-tn-red" />
            </div>
          </div>
          <p class="mb-3 text-sm text-tn-comment">
            AI tools have no idea what project you're in. You re-explain your stack on every session.
          </p>
          <div class="border-t border-white/[0.06] pt-3 flex items-start gap-2">
            <Icon name="lucide:check" class="h-4 w-4 text-coren-accent mt-0.5 shrink-0" />
            <p class="text-sm text-tn-text">Coren is workspace-aware. Project context loads automatically into every session.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── FEATURES ──────────────────────────────────────────────── -->
  <section class="px-6 py-24" id="features">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16 text-center reveal">
        <h2 class="section-title">Everything you need.<br class="hidden sm:block" />Nothing you don't.</h2>
        <p class="section-subtitle">A complete AI-native terminal workflow without the cloud dependency.</p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {features.map((feature, index) => (
          <div class={`card reveal reveal-delay-${(index % 3) + 1}`}>
            <div class={`mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg ${feature.bg}`}>
              <Icon name={feature.icon} class={`h-5 w-5 ${feature.color}`} />
            </div>
            <h3 class="mb-2 font-bold text-tn-text">{feature.title}</h3>
            <p class="text-sm leading-relaxed text-tn-comment">{feature.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── MODES ─────────────────────────────────────────────────── -->
  <section id="modes" class="relative overflow-hidden px-6 py-24">
    <div class="absolute inset-0 bg-tn-night/40 pointer-events-none"></div>
    <div class="absolute left-1/2 top-1/2 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-coren-accent/[0.04] blur-3xl pointer-events-none"></div>

    <div class="relative mx-auto max-w-6xl">
      <div class="mb-16 text-center reveal">
        <h2 class="section-title">One terminal. Four ways to think.</h2>
        <p class="section-subtitle">Different tasks need different levels of AI involvement. Dial in exactly how much help you want.</p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {modes.map((mode, index) => (
          <div class={`rounded-xl border bg-tn-storm/30 p-6 transition-all duration-300 hover:bg-tn-storm/50 ${mode.border} reveal reveal-delay-${index + 1}`}>
            <div class="flex items-start gap-4">
              <div class={`flex h-12 w-12 shrink-0 items-center justify-center rounded-xl text-xl font-bold ${mode.bg} ${mode.iconColor}`}>
                {mode.icon}
              </div>
              <div>
                <div class="mb-1 flex items-center gap-2">
                  <h3 class="text-lg font-bold text-tn-text">{mode.name}</h3>
                  <span class={`rounded-full px-2 py-0.5 text-xs ${mode.bg} ${mode.iconColor}`}>{mode.tag}</span>
                </div>
                <p class="text-sm leading-relaxed text-tn-comment">{mode.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── PRIVACY ───────────────────────────────────────────────── -->
  <section id="privacy" class="relative overflow-hidden px-6 py-28">
    <div class="absolute inset-0 bg-tn-night/60 pointer-events-none"></div>
    <div class="absolute left-1/2 top-1/2 h-[800px] w-[800px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-coren-accent/[0.05] blur-3xl pointer-events-none"></div>

    <div class="relative mx-auto max-w-5xl">
      <div class="mb-12 text-center reveal">
        <p class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-coren-accent">Privacy</p>
        <h2 class="section-title">
          We built Coren because we got tired of<br class="hidden sm:block" />
          pasting production code into browser tabs.
        </h2>
      </div>

      <div class="mx-auto mb-12 max-w-3xl reveal reveal-delay-1">
        <div class="rounded-2xl border border-coren-accent/25 bg-coren-accent/5 px-8 py-10 text-center">
          <blockquote class="mb-3 text-2xl font-bold gradient-text md:text-3xl">
            "Your code never leaves your machine."
          </blockquote>
          <p class="text-sm text-tn-comment">That's not a slogan. It's the architecture.</p>
        </div>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        <div class="reveal reveal-delay-2 card text-center">
          <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-coren-accent/10">
            <Icon name="lucide:server" class="h-5 w-5 text-coren-accent" />
          </div>
          <h3 class="mb-2 font-bold text-tn-text">Local proxy</h3>
          <p class="text-sm leading-relaxed text-tn-comment">
            All AI requests pass through a proxy running on your machine. Nothing is forwarded unless you choose a cloud provider.
          </p>
        </div>

        <div class="reveal reveal-delay-3 card text-center">
          <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-coren-accent/10">
            <Icon name="lucide:database" class="h-5 w-5 text-coren-accent" />
          </div>
          <h3 class="mb-2 font-bold text-tn-text">Local storage</h3>
          <p class="text-sm leading-relaxed text-tn-comment">
            Conversation history and provider config are stored locally. No telemetry, no sync to a remote server.
          </p>
        </div>

        <div class="reveal reveal-delay-4 card text-center">
          <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-coren-accent/10">
            <Icon name="lucide:wifi-off" class="h-5 w-5 text-coren-accent" />
          </div>
          <h3 class="mb-2 font-bold text-tn-text">Air-gap ready</h3>
          <p class="text-sm leading-relaxed text-tn-comment">
            Run entirely offline with Ollama. Enterprise teams can deploy with no outbound network access at all.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── COMPARISON ────────────────────────────────────────────── -->
  <section class="px-6 py-24" id="compare">
    <div class="mx-auto max-w-5xl">
      <div class="mb-16 text-center reveal">
        <h2 class="section-title">How Coren compares</h2>
        <p class="section-subtitle">vs cloud-first AI terminals</p>
      </div>

      <div class="reveal reveal-delay-1 overflow-hidden rounded-xl border border-white/[0.08]">
        <!-- Header -->
        <div class="grid grid-cols-3 border-b border-white/[0.08] bg-tn-night/60 px-6 py-3 text-xs font-bold uppercase tracking-[0.15em]">
          <span class="text-tn-muted">Feature</span>
          <span class="text-center text-coren-accent">Coren</span>
          <span class="text-center text-tn-muted">Cloud alternatives</span>
        </div>
        <!-- Rows -->
        {comparisonRows.map((row, i) => (
          <div class={`grid grid-cols-3 items-center px-6 py-3.5 text-sm border-b border-white/[0.05] last:border-0 ${i % 2 === 0 ? 'bg-white/[0.01]' : ''}`}>
            <span class="text-tn-subtext">{row.feature}</span>
            <span class={`text-center font-semibold ${row.coren === '✓' ? 'text-tn-green' : 'text-tn-text'}`}>
              {row.coren}
            </span>
            <span class={`text-center font-semibold ${row.cloud === '✗' ? 'text-tn-red/70' : 'text-tn-comment'}`}>
              {row.cloud}
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── ENTERPRISE ────────────────────────────────────────────── -->
  <section class="px-6 py-24">
    <div class="mx-auto max-w-5xl">
      <div class="reveal rounded-2xl border border-coren-accent/20 bg-gradient-to-br from-coren-accent/10 via-transparent to-transparent p-10 md:p-16">
        <div class="grid items-start gap-12 md:grid-cols-2">
          <div>
            <p class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-coren-accent">Enterprise</p>
            <h2 class="mb-6 text-3xl font-bold tracking-tight text-tn-text">
              For teams that can't afford a data leak.
            </h2>
            <p class="mb-8 leading-relaxed text-tn-subtext">
              Coren is built for environments where compliance isn't optional. Route AI requests to your own models, never to shared infrastructure.
            </p>
            <button class="btn-primary" disabled>
              <Icon name="lucide:mail" class="h-4 w-4" />
              Talk to us about deployment
            </button>
          </div>

          <div class="space-y-4">
            {[
              { icon: 'lucide:route', text: 'Route all requests to your own models — never to shared cloud infrastructure.' },
              { icon: 'lucide:wifi-off', text: 'Air-gap deployments with local Ollama or any OpenAI-compatible endpoint.' },
              { icon: 'lucide:folder-lock', text: 'Per-project workspace context keeps team knowledge scoped and private.' },
              { icon: 'lucide:key', text: 'No API key sharing — each developer brings their own credentials.' },
            ].map((item) => (
              <div class="flex items-start gap-3">
                <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-coren-accent/10">
                  <Icon name={item.icon} class="h-4 w-4 text-coren-accent" />
                </div>
                <p class="text-sm leading-relaxed text-tn-subtext">{item.text}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── THEMES ────────────────────────────────────────────────── -->
  <section id="themes" class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16 text-center reveal">
        <h2 class="section-title">Your terminal, your aesthetic.</h2>
        <p class="section-subtitle">Four carefully crafted themes built for long coding sessions. Switch instantly — no restart needed.</p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        {themes.map((theme, index) => (
          <div class={`card reveal reveal-delay-${index + 1} flex flex-col gap-4`}>
            <div class="flex gap-1.5">
              {theme.colors.map((color) => (
                <span
                  class="h-5 w-5 rounded-full border border-white/10 flex-shrink-0"
                  style={`background-color: ${color}`}
                ></span>
              ))}
            </div>
            <div class="rounded-lg overflow-hidden border border-white/[0.07]" style={`background-color: ${theme.bg}`}>
              <div class="flex items-center gap-1 px-2 py-1.5 border-b border-white/[0.06]" style={`background-color: ${theme.bg}`}>
                <span class="h-2 w-2 rounded-full bg-tn-red/60"></span>
                <span class="h-2 w-2 rounded-full bg-tn-yellow/60"></span>
                <span class="h-2 w-2 rounded-full bg-tn-green/60"></span>
              </div>
              <div class="p-3 text-xs font-mono space-y-1">
                <div style={`color: ${theme.accent}`}>✦ {theme.key}</div>
                <div class="text-white/40">▸ you</div>
                <div style={`color: ${theme.accent}`}>▸ ai</div>
              </div>
            </div>
