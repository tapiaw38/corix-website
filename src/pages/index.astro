---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
---

<Layout>
  <!-- ── HERO ─────────────────────────────────────────────── -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden px-6">
    <!-- Background blobs -->
    <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-corix-accent/[0.06] rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 right-1/4 w-[400px] h-[400px] bg-ctp-blue/[0.05] rounded-full blur-3xl pointer-events-none"></div>

    <div class="max-w-6xl mx-auto w-full grid md:grid-cols-2 gap-12 items-center py-24">
      <!-- Text -->
      <div class="reveal">
        <div class="inline-flex items-center gap-2 text-xs border border-corix-accent/30 bg-corix-accent/[0.06] text-corix-accent px-3 py-1.5 rounded-full mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-corix-accent animate-pulse-slow"></span>
          AI-native terminal
        </div>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-ctp-text mb-6 leading-tight tracking-tight">
          The terminal<br/>
          <span class="gradient-text">that thinks</span>
        </h1>
        <p class="text-ctp-subtext1 text-lg mb-8 leading-relaxed max-w-md">
          corix embeds an AI panel directly in your terminal. Watch commands, detect errors, suggest fixes — all without leaving the CLI.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#install" class="btn-primary">
            <Icon name="lucide:download" class="w-4 h-4" />
            Install now
          </a>
          <a href="#modes" class="btn-secondary">
            <Icon name="lucide:play-circle" class="w-4 h-4" />
            See modes
          </a>
        </div>
        <!-- Stats -->
        <div class="flex gap-8 mt-10 text-sm text-ctp-overlay0">
          <div>
            <span class="block text-xl font-bold text-ctp-text">4</span>
            AI modes
          </div>
          <div>
            <span class="block text-xl font-bold text-ctp-text">0ms</span>
            Startup
          </div>
          <div>
            <span class="block text-xl font-bold text-ctp-text">100%</span>
            Keyboard-first
          </div>
        </div>
      </div>

      <!-- Terminal preview -->
      <div class="reveal reveal-delay-2">
        <div class="terminal-window shadow-2xl shadow-black/50">
          <!-- Chrome -->
          <div class="terminal-chrome">
            <span class="w-3 h-3 rounded-full bg-ctp-red/80"></span>
            <span class="w-3 h-3 rounded-full bg-ctp-yellow/80"></span>
            <span class="w-3 h-3 rounded-full bg-ctp-green/80"></span>
            <span class="ml-auto text-xs text-ctp-overlay0">corix — ~/projects/myapp</span>
          </div>
          <!-- Status bar -->
          <div class="flex items-center gap-3 px-3 py-1.5 bg-ctp-surface0/60 text-xs border-b border-white/[0.05]">
            <span class="bg-corix-accent text-ctp-base px-2 py-0.5 rounded font-bold">Agent</span>
            <span class="text-ctp-overlay0">watch</span>
            <span class="text-ctp-overlay0 ml-1">📁 myapp</span>
            <span class="text-ctp-overlay0 ml-1"> main</span>
            <span class="ml-auto text-ctp-overlay0">^O panel   ^Q quit</span>
          </div>
          <!-- Terminal content -->
          <div class="p-4 text-sm font-mono space-y-1 min-h-[200px]">
            <div><span class="text-ctp-green">❯</span> <span class="text-ctp-text">docker compose up -d</span></div>
            <div class="text-ctp-overlay0 pl-2">Starting containers...</div>
            <div class="text-ctp-red pl-2">Error: port 5432 already in use</div>
            <div class="text-ctp-overlay0 pl-2">...</div>
          </div>
          <!-- AI panel -->
          <div class="border-t border-white/[0.08]">
            <div class="flex items-center justify-between px-4 py-2 text-xs text-ctp-overlay0 border-b border-white/[0.05]">
              <span class="text-corix-accent font-bold">✦</span>
              <span class="text-ctp-overlay0">watch</span>
              <span class="ml-auto">esc  ^O</span>
            </div>
            <div class="p-4 text-xs font-mono space-y-1.5 bg-ctp-mantle/50">
              <p class="text-ctp-subtext1">Port <span class="text-ctp-peach">5432</span> (PostgreSQL) is already in use. Another process is holding the port.</p>
              <p class="text-ctp-subtext1 mt-2">To find and stop it:</p>
              <p class="text-ctp-green pl-2">lsof -ti:5432 | xargs kill -9</p>
            </div>
            <div class="px-4 py-2 border-t border-white/[0.05]">
              <div class="flex items-center gap-2 text-xs text-ctp-overlay0">
                <span class="text-ctp-accent">❯</span>
                <span class="text-ctp-overlay0/50">Message…</span>
                <span class="ml-auto animate-blink text-corix-accent">█</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FEATURES ──────────────────────────────────────────── -->
  <section id="features" class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 reveal">
        <h2 class="section-title">Everything you need,<br/><span class="gradient-text">nothing you don't</span></h2>
        <p class="section-subtitle">A full terminal emulator with AI built at the core — not bolted on.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {[
          {
            icon: 'lucide:zap',
            color: 'text-ctp-yellow',
            bg: 'bg-ctp-yellow/10',
            title: 'Zero overhead',
            desc: 'Built in Go with bubbletea. Instant startup, no Electron, no Node — just a fast binary.',
          },
          {
            icon: 'lucide:palette',
            color: 'text-corix-accent',
            bg: 'bg-corix-accent/10',
            title: 'Catppuccin Mocha',
            desc: 'Ships with the beloved Catppuccin Mocha theme. Easy on the eyes, even at 2am.',
          },
          {
            icon: 'lucide:git-branch',
            color: 'text-ctp-green',
            bg: 'bg-ctp-green/10',
            title: 'Git-aware status bar',
            desc: 'Current folder, git branch, and mode always visible. No more context-switching.',
          },
          {
            icon: 'lucide:mouse-pointer-2',
            color: 'text-ctp-blue',
            bg: 'bg-ctp-blue/10',
            title: 'Mouse support',
            desc: 'Click to select, scroll to browse history. Copy-on-select and middle-click paste.',
          },
          {
            icon: 'lucide:search',
            color: 'text-ctp-teal',
            bg: 'bg-ctp-teal/10',
            title: 'Built-in search',
            desc: 'Press ^F to search through terminal output with live match highlighting.',
          },
          {
            icon: 'lucide:keyboard',
            color: 'text-ctp-peach',
            bg: 'bg-ctp-peach/10',
            title: 'Keyboard-first',
            desc: '^O to toggle AI panel, ^G to switch focus, ^Q to quit. No mouse required.',
          },
        ].map((f, i) => (
          <div class={`card reveal reveal-delay-${(i % 3) + 1}`}>
            <div class={`inline-flex items-center justify-center w-10 h-10 rounded-lg ${f.bg} mb-4`}>
              <Icon name={f.icon} class={`w-5 h-5 ${f.color}`} />
            </div>
            <h3 class="font-bold text-ctp-text mb-2">{f.title}</h3>
            <p class="text-sm text-ctp-overlay0 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── MODES ─────────────────────────────────────────────── -->
  <section id="modes" class="py-24 px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-ctp-mantle/40 pointer-events-none"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-corix-accent/[0.04] rounded-full blur-3xl pointer-events-none"></div>

    <div class="max-w-6xl mx-auto relative">
      <div class="text-center mb-16 reveal">
        <h2 class="section-title">Four modes,<br/><span class="gradient-text">one terminal</span></h2>
        <p class="section-subtitle">Switch modes with <code class="text-corix-accent bg-corix-accent/10 px-1.5 py-0.5 rounded">/mode</code> and let corix adapt to how you work.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {[
          {
            icon: '?',
            iconColor: 'text-ctp-blue',
            bg: 'bg-ctp-blue/10',
            border: 'border-ctp-blue/20',
            name: 'Default',
            tag: 'Ask anything',
            desc: 'Classic AI chat panel. Ask questions, get explanations, explore documentation — all without leaving the terminal.',
            features: ['Markdown rendering', 'Conversation history', 'File path completion'],
          },
          {
            icon: '◉',
            iconColor: 'text-ctp-green',
            bg: 'bg-ctp-green/10',
            border: 'border-ctp-green/20',
            name: 'Watch',
            tag: 'Auto-context',
            desc: 'Sends every command and its output to the AI automatically. Get instant context and suggestions as you work.',
            features: ['Smart debounce — waits for output', 'Command + response captured', 'Zero extra keystrokes'],
          },
          {
            icon: '⚡',
            iconColor: 'text-corix-accent',
            bg: 'bg-corix-accent/10',
            border: 'border-corix-accent/20',
            name: 'Execute',
            tag: 'AI suggests, you confirm',
            desc: 'The AI analyzes your commands and proposes next steps as selectable chips. Pick one and run it with Enter.',
            features: ['Command chips with ↑↓ navigation', 'Confirm before running', 'AI-proposed commands via overlay'],
          },
          {
            icon: '🔧',
            iconColor: 'text-ctp-peach',
            bg: 'bg-ctp-peach/10',
            border: 'border-ctp-peach/20',
            name: 'Debug',
            tag: 'Error detection',
            desc: 'Only triggers when the AI detects an error in the output. Explains what went wrong and gives the exact fix.',
            features: ['Detects 15+ error patterns', 'Silent on success', 'Asks before running fixes'],
          },
        ].map((m, i) => (
          <div class={`bg-ctp-surface0/30 rounded-xl p-6 border ${m.border} reveal reveal-delay-${i + 1} hover:bg-ctp-surface0/50 transition-all duration-300`}>
            <div class="flex items-start gap-4">
              <div class={`w-12 h-12 rounded-xl ${m.bg} flex items-center justify-center text-xl font-bold ${m.iconColor} shrink-0`}>
                {m.icon}
              </div>
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <h3 class="font-bold text-ctp-text text-lg">{m.name}</h3>
                  <span class={`text-xs px-2 py-0.5 rounded-full ${m.bg} ${m.iconColor}`}>{m.tag}</span>
                </div>
                <p class="text-ctp-overlay0 text-sm leading-relaxed mb-4">{m.desc}</p>
                <ul class="space-y-1.5">
                  {m.features.map(f => (
                    <li class="flex items-center gap-2 text-sm text-ctp-subtext1">
                      <Icon name="lucide:check" class={`w-3.5 h-3.5 shrink-0 ${m.iconColor}`} />
                      {f}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── PRICING ──────────────────────────────────────────────── -->
  <section id="pricing" class="py-24 px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-ctp-mantle/30 pointer-events-none"></div>
    <div class="max-w-6xl mx-auto relative">
      <div class="text-center mb-16 reveal">
        <h2 class="section-title">Simple pricing,<br/><span class="gradient-text">no surprises</span></h2>
        <p class="section-subtitle">Bring your own API key from any provider. We charge for the software, not the tokens.</p>
      </div>

      <!-- Pricing cards -->
      <div class="grid md:grid-cols-3 gap-6 pt-6 mb-16">
        <!-- Starter -->
        <div class="card reveal reveal-delay-1 flex flex-col">
          <div class="mb-4">
            <h3 class="font-bold text-ctp-text text-xl mb-1">Starter</h3>
            <p class="text-ctp-overlay0 text-sm">For solo devs</p>
          </div>
          <div class="mb-6">
            <span class="text-4xl font-bold text-ctp-text">$2</span>
            <span class="text-ctp-overlay0 text-sm">/month</span>
          </div>
          <ul class="space-y-3 mb-8 flex-1">
            {[
              'corix terminal',
              'Default mode (ask)',
              'Watch mode',
              'Bring your own API key',
              'Any AI provider',
              'corix-proxy included',
              'Catppuccin theme',
              'Mouse & search',
            ].map(f => (
              <li class="flex items-center gap-2 text-sm text-ctp-subtext1">
                <Icon name="lucide:check" class="w-4 h-4 text-ctp-green shrink-0" />
                {f}
              </li>
            ))}
            {['Execute mode', 'Debug mode', 'Priority support'].map(f => (
              <li class="flex items-center gap-2 text-sm text-ctp-overlay0">
                <Icon name="lucide:minus" class="w-4 h-4 text-ctp-surface1 shrink-0" />
                {f}
              </li>
            ))}
          </ul>
          <a href="#install" class="btn-secondary justify-center">Get started</a>
        </div>

        <!-- Pro — highlighted -->
        <div class="relative rounded-xl p-6 border border-corix-accent/40 bg-corix-accent/[0.05] flex flex-col reveal reveal-delay-2 scale-[1.03] shadow-[0_0_40px_0_rgba(203,166,247,0.12)]">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="bg-corix-accent text-ctp-base text-xs font-bold px-3 py-1 rounded-full">Most popular</span>
          </div>
          <div class="mb-4">
            <h3 class="font-bold text-ctp-text text-xl mb-1">Pro</h3>
            <p class="text-ctp-overlay0 text-sm">For power users</p>
          </div>
          <div class="mb-6">
            <span class="text-4xl font-bold text-ctp-text">$5</span>
            <span class="text-ctp-overlay0 text-sm">/month</span>
          </div>
          <ul class="space-y-3 mb-8 flex-1">
            {[
              'Everything in Starter',
              'Execute mode',
              'Debug mode',
              'Priority bug fixes',
              'Early access to new features',
              'Community Discord access',
            ].map(f => (
              <li class="flex items-center gap-2 text-sm text-ctp-subtext1">
                <Icon name="lucide:check" class="w-4 h-4 text-corix-accent shrink-0" />
                {f}
              </li>
            ))}
          </ul>
          <a href="#install" class="btn-primary justify-center">Get Pro</a>
        </div>

        <!-- Teams -->
        <div class="relative rounded-xl p-6 border border-ctp-blue/30 bg-ctp-blue/[0.04] flex flex-col reveal reveal-delay-3">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="bg-ctp-blue text-ctp-base text-xs font-bold px-3 py-1 rounded-full">Teams & Enterprise</span>
          </div>
          <div class="mb-4">
            <h3 class="font-bold text-ctp-text text-xl mb-1">Team</h3>
            <p class="text-ctp-overlay0 text-sm">For engineering teams</p>
          </div>
          <div class="mb-6">
            <span class="text-4xl font-bold text-ctp-text">$20</span>
            <span class="text-ctp-overlay0 text-sm">/user/month</span>
          </div>
          <ul class="space-y-3 mb-8 flex-1">
            {[
              'Everything in Pro',
              'Priority support (24h SLA)',
              'Priority feature requests',
              'Early access to all updates',
              'Dedicated onboarding',
              'Custom AI provider config',
              'Team license management',
              'Invoice billing available',
            ].map(f => (
              <li class="flex items-center gap-2 text-sm text-ctp-subtext1">
                <Icon name="lucide:check" class="w-4 h-4 text-ctp-blue shrink-0" />
                {f}
              </li>
            ))}
          </ul>
          <a href="mailto:hello@corix.dev" class="btn-secondary justify-center border-ctp-blue/30 hover:border-ctp-blue/60">
            <Icon name="lucide:mail" class="w-4 h-4" />
            Contact us
          </a>
        </div>
      </div>

      <!-- Comparison bar -->
      <div class="mb-12 reveal reveal-delay-2 bg-ctp-surface0/30 rounded-xl border border-white/[0.06] overflow-hidden">
        <div class="grid grid-cols-5 text-xs text-ctp-overlay0 uppercase tracking-wider border-b border-white/[0.06]">
          <div class="col-span-1 px-4 py-3">Tool</div>
          <div class="px-4 py-3 text-center">Price</div>
          <div class="px-4 py-3 text-center hidden md:block">Native binary</div>
          <div class="px-4 py-3 text-center hidden md:block">Any AI provider</div>
          <div class="px-4 py-3 text-center">AI modes</div>
        </div>
        {[
          { name: 'Warp',             price: '$22/user', native: false, anyKey: false, modes: '1' },
          { name: 'Copilot CLI',      price: '$10/mo',   native: false, anyKey: false, modes: '—' },
          { name: 'Cursor',           price: '$20/mo',   native: false, anyKey: false, modes: '—' },
          { name: 'corix Pro',       price: '$5/mo',    native: true,  anyKey: true,  modes: '4', highlight: true },
        ].map(r => (
          <div class={`grid grid-cols-5 text-sm border-b border-white/[0.04] last:border-0 ${r.highlight ? 'bg-corix-accent/[0.05]' : ''}`}>
            <div class={`col-span-1 px-4 py-3 font-medium ${r.highlight ? 'text-corix-accent' : 'text-ctp-text'}`}>
              {r.highlight
                ? r.name
                : <span class="blur-sm select-none">{r.name}</span>}
            </div>
            <div class={`px-4 py-3 text-center font-mono ${r.highlight ? 'text-ctp-green font-bold' : 'text-ctp-red'}`}>{r.price}</div>
            <div class="px-4 py-3 text-center hidden md:flex items-center justify-center">
              {r.native
                ? <Icon name="lucide:check" class="w-4 h-4 text-ctp-green" />
                : <Icon name="lucide:x" class="w-4 h-4 text-ctp-surface2" />}
            </div>
            <div class="px-4 py-3 text-center hidden md:flex items-center justify-center">
              {r.anyKey
                ? <Icon name="lucide:check" class="w-4 h-4 text-ctp-green" />
                : <Icon name="lucide:x" class="w-4 h-4 text-ctp-surface2" />}
            </div>
            <div class={`px-4 py-3 text-center ${r.highlight ? 'text-corix-accent font-bold' : 'text-ctp-overlay0'}`}>{r.modes}</div>
          </div>
        ))}
      </div>

      <!-- Advantage pills -->
      <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-4 reveal reveal-delay-2">
        {[
          { icon: 'lucide:key', color: 'text-ctp-green', title: 'Your API key', desc: 'Connect DeepSeek, OpenAI, Anthropic, or local Ollama. Zero lock-in.' },
          { icon: 'lucide:cpu', color: 'text-ctp-blue', title: 'Native binary', desc: 'Go binary, no Electron, no Node. Starts in milliseconds.' },
          { icon: 'lucide:dollar-sign', color: 'text-corix-accent', title: '4× cheaper', desc: '$5/mo vs $22/mo for Warp. Same AI power, less overhead.' },
          { icon: 'lucide:wifi-off', color: 'text-ctp-peach', title: 'Works offline', desc: 'Terminal works without internet. AI only needs your key.' },
        ].map(a => (
          <div class="bg-ctp-surface0/30 rounded-lg p-4 border border-white/[0.06] text-center">
            <div class={`inline-flex items-center justify-center w-9 h-9 rounded-lg bg-white/[0.05] mb-3 ${a.color}`}>
              <Icon name={a.icon} class="w-4 h-4" />
            </div>
            <h4 class="font-bold text-ctp-text text-sm mb-1">{a.title}</h4>
            <p class="text-ctp-overlay0 text-xs leading-relaxed">{a.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── INSTALL ────────────────────────────────────────────── -->
  <section id="install" class="py-24 px-6">
    <div class="max-w-3xl mx-auto">
      <div class="text-center reveal">
        <h2 class="section-title">Up and running in<br/><span class="gradient-text">two commands</span></h2>
        <p class="section-subtitle">corix + corix-proxy. One installs the terminal, the other connects your AI provider.</p>
      </div>

      <div class="space-y-4 reveal reveal-delay-1 text-left">
        <!-- One-liner install -->
        <div class="terminal-window">
          <div class="terminal-chrome">
            <span class="w-2.5 h-2.5 rounded-full bg-ctp-red/60"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-ctp-yellow/60"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-ctp-green/60"></span>
            <span class="ml-3 text-xs text-ctp-overlay0 font-bold">Step 1 — Install both binaries</span>
          </div>
          <pre class="p-4 text-sm font-mono overflow-x-auto"><code><span class="text-ctp-overlay0"># installs corix + corix-proxy</span>
<span class="text-ctp-green">curl -fsSL https://corix.dev/install.sh | sh</span></code></pre>
        </div>

        <!-- Configure proxy -->
        <div class="terminal-window">
          <div class="terminal-chrome">
            <span class="w-2.5 h-2.5 rounded-full bg-ctp-red/60"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-ctp-yellow/60"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-ctp-green/60"></span>
            <span class="ml-3 text-xs text-ctp-overlay0 font-bold">Step 2 — Connect your API key</span>
          </div>
          <pre class="p-4 text-sm font-mono overflow-x-auto"><code><span class="text-ctp-overlay0"># set your provider (DeepSeek, OpenAI, Ollama…)</span>
<span class="text-ctp-green">corix-proxy init</span>

<span class="text-ctp-overlay0">  Provider  → deepseek</span>
<span class="text-ctp-overlay0">  API key   → sk-••••••••••••••••</span>
<span class="text-ctp-overlay0">  ✓ Config saved to ~/.config/corix-proxy/config</span></code></pre>
        </div>

        <!-- Run -->
        <div class="terminal-window">
          <div class="terminal-chrome">
            <span class="w-2.5 h-2.5 rounded-full bg-ctp-red/60"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-ctp-yellow/60"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-ctp-green/60"></span>
            <span class="ml-3 text-xs text-ctp-overlay0 font-bold">Step 3 — Launch</span>
          </div>
          <pre class="p-4 text-sm font-mono overflow-x-auto"><code><span class="text-ctp-green">corix-proxy service start</span>   <span class="text-ctp-overlay0"># runs in background</span>
<span class="text-ctp-green">corix</span>                        <span class="text-ctp-overlay0"># open the terminal</span>

<span class="text-ctp-overlay0">  ^O  →  toggle AI panel</span>
<span class="text-ctp-overlay0">  ^G  →  switch focus</span>
<span class="text-ctp-overlay0">  /mode  →  switch AI mode</span></code></pre>
        </div>
      </div>

      <!-- Supported providers -->
      <div class="mt-8 reveal reveal-delay-3">
        <p class="text-xs text-ctp-overlay0 mb-3 uppercase tracking-wider text-center">Supported providers</p>
        <div class="flex flex-wrap justify-center gap-3">
          {['DeepSeek', 'OpenAI', 'Anthropic', 'Ollama (local)', 'Groq', 'Mistral'].map(p => (
