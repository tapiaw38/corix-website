---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';

const sidebar = [
  {
    title: 'Get Started',
    icon: 'lucide:rocket',
    links: [
      ['what-is-coren', 'What is coren?'],
      ['components', 'Components'],
      ['requirements', 'Requirements'],
    ],
  },
  {
    title: 'Installation',
    icon: 'lucide:download',
    links: [
      ['install-coren', 'Install binaries'],
      ['bootstrap-proxy', 'Bootstrap proxy'],
      ['run-stack', 'Run the stack'],
    ],
  },
  {
    title: 'Configuration',
    icon: 'lucide:settings',
    links: [
      ['coren-config', 'coren config'],
      ['providers', 'Providers'],
    ],
  },
  {
    title: 'Runtime',
    icon: 'lucide:brain',
    links: [
      ['modes', 'AI modes'],
      ['panel-commands', 'Panel commands'],
      ['project-memory', 'Project memory'],
      ['shortcuts', 'Keyboard'],
      ['service', 'User service'],
    ],
  },
  {
    title: 'Troubleshooting',
    icon: 'lucide:wrench',
    links: [
      ['port-mismatch', 'Port mismatch'],
      ['mongo', 'MongoDB'],
      ['workspace', 'Workspace export'],
    ],
  },
];

const corenConfig = [
  ['copy-on-select', 'true', 'Auto-copy selected text.'],
  ['middle-click-paste', 'true', 'Paste with middle click into the terminal session.'],
  ['ai-panel-height', '18', 'Panel height when docked top or bottom.'],
  ['ai-panel-width', '80', 'Panel width when docked left or right.'],
  ['ai-panel-open', 'false', 'Open the AI panel at startup.'],
  ['ai-suggest', 'true', 'Enable inline AI suggestions while typing.'],
  ['inline-assist', 'true', 'Enable inline hints after command execution.'],
  ['proxy-url', 'empty', 'Base URL for the proxy, for example `http://127.0.0.1:4000`.'],
  ['workspace', 'empty', 'Workspace path sent to the proxy as context.'],
  ['language', 'empty', 'Preferred language for generated AI content such as default pull request bodies. Falls back to the shell locale when unset.'],
  ['editor', 'empty', 'Editor command used when opening files from overlays (e.g. `/context`). Falls back to `$VISUAL`, then `$EDITOR`, then tries `vi`, `nano`, `micro` in order.'],
  ['theme', 'catppuccin', 'Color theme: `catppuccin`, `dracula`, `rosepine`, or `tokyonight`.'],
  ['cursor-style', 'block', 'Terminal cursor shape: `block`, `underline`, or `bar`.'],
];

const providers = [
  ['ollama', 'http://127.0.0.1:11434/v1', 'gemma4:latest'],
  ['deepseek', 'https://api.deepseek.com', 'deepseek-chat'],
  ['openai', 'https://api.openai.com/v1', 'gpt-4o'],
  ['anthropic', 'https://api.anthropic.com/v1', 'claude-sonnet-4-6'],
  ['gemini', 'https://generativelanguage.googleapis.com/v1beta/openai/', 'gemini-2.0-flash'],
  ['groq', 'https://api.groq.com/openai/v1', 'llama-3.3-70b-versatile'],
];
---

<Layout
  title="Documentation — coren"
  description="Installation and runtime notes for coren, coren-proxi, and corend."
>
  <div class="min-h-screen flex">
    <aside class="sticky top-16 hidden h-[calc(100vh-4rem)] w-64 shrink-0 overflow-y-auto border-r border-white/[0.06] bg-tn-bg px-5 py-8 lg:flex xl:w-72">
      <div class="w-full">
        <p class="mb-4 px-2 text-xs font-bold uppercase tracking-widest text-tn-muted">Documentation</p>
        <nav class="flex flex-col gap-3">
          {sidebar.map((group) => (
            <div>
              <p class="mb-1 flex items-center gap-2 px-2 text-sm font-semibold text-tn-subtext">
                <Icon name={group.icon} class="h-3.5 w-3.5 opacity-60" />
                {group.title}
              </p>
              <div class="flex flex-col gap-0.5 pl-5">
                {group.links.map(([href, label]) => (
                  <a href={`#${href}`} class="rounded px-2 py-1 text-sm text-tn-muted transition-colors hover:text-tn-text">{label}</a>
                ))}
              </div>
            </div>
          ))}
        </nav>

        <div class="mt-8 rounded-lg bg-tn-storm/50 px-3 py-3 text-xs text-tn-muted">
          The docs below describe the binary distribution flow exposed through `https://tapiaw38.github.io/coren-website/install.sh`.
        </div>
      </div>
    </aside>

    <div class="min-w-0 flex-1">
      <div class="mx-auto max-w-4xl px-6 py-12 pb-32 lg:px-10">
        <section class="mb-20">
          <div class="mb-8 flex items-center gap-3">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-coren-accent/10">
              <Icon name="lucide:book-open" class="h-4 w-4 text-coren-accent" />
            </div>
            <h1 class="text-3xl font-bold text-tn-text">coren documentation</h1>
          </div>
          <p class="text-lg leading-relaxed text-tn-subtext">
            `coren` is the terminal app. `coren-proxi` is the local HTTP proxy. `corend` is the operator CLI for the proxy, database, providers, shell integration, memory inspection, and the user service.
          </p>
        </section>

        <hr class="mb-20 border-white/[0.06]" />

        <section class="doc-section mb-20">
          <div class="mb-8 flex items-center gap-3">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-coren-accent/10">
              <Icon name="lucide:rocket" class="h-4 w-4 text-coren-accent" />
            </div>
            <h2 class="text-3xl font-bold text-tn-text">Get Started</h2>
          </div>

          <h3 id="what-is-coren" class="mb-4 scroll-mt-24 text-xl font-semibold text-tn-text">What is coren?</h3>
          <p class="mb-6 leading-relaxed text-tn-subtext">
            It is a Go terminal interface that runs a real shell session, renders it inside the app, and can attach an AI panel that talks to the local proxy API.
          </p>

          <h3 id="components" class="mb-4 scroll-mt-24 text-xl font-semibold text-tn-text">Components</h3>
          <div class="grid gap-4 md:grid-cols-3">
            <div class="card p-5">
              <h4 class="mb-2 font-semibold text-tn-text">`coren`</h4>
              <p class="text-sm leading-relaxed text-tn-subtext">Interactive terminal UI. Supports panel position state, AI modes, inline assist, scrollback, mouse support, and conversation attachment via `--conv-id`.</p>
            </div>
            <div class="card p-5">
              <h4 class="mb-2 font-semibold text-tn-text">`coren-proxi`</h4>
              <p class="text-sm leading-relaxed text-tn-subtext">HTTP server for providers, conversations, inline assist, command completion, and shell-session tool interactions. Defaults to `127.0.0.1:4000`.</p>
            </div>
            <div class="card p-5">
              <h4 class="mb-2 font-semibold text-tn-text">`corend`</h4>
              <p class="text-sm leading-relaxed text-tn-subtext">CLI for setup and operations: `init`, `provider`, `db`, `shell`, `service`, `memory`, and `inspect`.</p>
            </div>
          </div>

          <h3 id="requirements" class="mb-4 mt-10 scroll-mt-24 text-xl font-semibold text-tn-text">Requirements</h3>
          <ul class="space-y-2 text-tn-subtext">
            <li class="flex items-start gap-2"><span class="mt-1 text-coren-accent">›</span> MongoDB via Docker or Docker Compose for the default local proxy persistence flow.</li>
            <li class="flex items-start gap-2"><span class="mt-1 text-coren-accent">›</span> `bash` or `zsh` if you want `corend shell init` to update your rc file.</li>
            <li class="flex items-start gap-2"><span class="mt-1 text-coren-accent">›</span> At least one provider API key unless you use a custom endpoint without auth.</li>
            <li class="flex items-start gap-2"><span class="mt-1 text-coren-accent">›</span> Linux is the only supported platform right now.</li>
            <li class="flex items-start gap-2"><span class="mt-1 text-coren-accent">›</span> macOS support is planned for a later release.</li>
          </ul>
        </section>

        <hr class="mb-20 border-white/[0.06]" />

        <section class="doc-section mb-20">
          <div class="mb-8 flex items-center gap-3">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-coren-accent/10">
              <Icon name="lucide:download" class="h-4 w-4 text-coren-accent" />
            </div>
            <h2 class="text-3xl font-bold text-tn-text">Installation</h2>
          </div>

          <h3 id="install-coren" class="mb-4 scroll-mt-24 text-xl font-semibold text-tn-text">Install binaries</h3>
          <p class="mb-4 leading-relaxed text-tn-subtext">
            The supported user path is a single binary installer. It downloads one platform bundle, verifies its checksum, installs `coren`, `coren-proxi`, and `corend`, and creates the `cor` alias.
          </p>
          <p class="mb-4 leading-relaxed text-tn-subtext">
            Release bundles are hosted as GitHub Release assets; the website only serves the installer script and docs.
          </p>
          <div class="terminal-window mb-8">
            <div class="terminal-chrome">
              <span class="h-2.5 w-2.5 rounded-full bg-tn-red/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-tn-yellow/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-tn-green/80"></span>
              <span class="ml-auto text-xs text-tn-muted">binary install</span>
            </div>
            <pre class="overflow-x-auto p-4 text-sm font-mono"><code><span class="text-tn-green">curl -fsSL https://tapiaw38.github.io/coren-website/install.sh | sh</span></code></pre>
          </div>
          <p class="mb-8 leading-relaxed text-tn-subtext">
            To pin a specific release, the installer also accepts `VERSION=v0.x.y`, for example `curl -fsSL https://tapiaw38.github.io/coren-website/install.sh | VERSION=v0.2.0 sh`.
          </p>

          <h3 id="bootstrap-proxy" class="mb-4 scroll-mt-24 text-xl font-semibold text-tn-text">Bootstrap proxy</h3>
          <p class="mb-4 leading-relaxed text-tn-subtext">
            `corend init` is the shortest valid bootstrap path. The wizard walks through every step interactively.
          </p>
          <div class="terminal-window mb-6">
            <div class="terminal-chrome">
              <span class="h-2.5 w-2.5 rounded-full bg-tn-red/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-tn-yellow/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-tn-green/80"></span>
              <span class="ml-auto text-xs text-tn-muted">bootstrap</span>
            </div>
            <pre class="overflow-x-auto p-4 text-sm font-mono"><code><span class="text-tn-green">corend init</span></code></pre>
          </div>
          <p class="mb-3 text-sm leading-relaxed text-tn-subtext">The wizard asks:</p>
          <ul class="mb-8 space-y-2 text-sm text-tn-subtext">
            <li class="flex items-start gap-2"><span class="mt-0.5 text-coren-accent">›</span> <strong class="text-tn-text">MongoDB source</strong> — <code>local</code> (MongoDB already installed on your machine, port 27017) or <code>docker</code> (managed container, default port 27027). The chosen port is saved to <code>~/.config/coren-proxi/.env</code>.</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-coren-accent">›</span> <strong class="text-tn-text">Shell integration</strong> — updates your rc file and sets <code>COREN_WORKSPACE</code>.</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-coren-accent">›</span> <strong class="text-tn-text">Provider setup</strong> — only shown for the <code>local</code> MongoDB path, where the database is assumed to be already running. For <code>docker</code>, run <code>corend db start</code> first, then <code>corend provider add</code>.</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-coren-accent">›</span> <strong class="text-tn-text">User service</strong> — installs and starts <code>coren-proxi</code> as a systemd user unit.</li>
          </ul>

          <h3 id="run-stack" class="mb-4 scroll-mt-24 text-xl font-semibold text-tn-text">Run the stack</h3>
          <p class="mb-4 leading-relaxed text-tn-subtext">
            If you chose <strong>docker</strong> during init, start MongoDB, configure a provider, then open the TUI.
          </p>
          <div class="terminal-window mb-6">
            <div class="terminal-chrome">
              <span class="h-2.5 w-2.5 rounded-full bg-tn-red/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-tn-yellow/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-tn-green/80"></span>
              <span class="ml-auto text-xs text-tn-muted">run (docker)</span>
            </div>
            <pre class="overflow-x-auto p-4 text-sm font-mono"><code><span class="text-tn-muted"># start the MongoDB container</span>
<span class="text-tn-green">corend db start</span>

<span class="text-tn-muted"># configure an AI provider</span>
<span class="text-tn-green">corend provider add</span>

<span class="text-tn-muted"># open the TUI</span>
<span class="text-tn-green">coren</span></code></pre>
          </div>
          <p class="mb-4 leading-relaxed text-tn-subtext">
            If you chose <strong>local</strong>, MongoDB is already managed by you. The proxy service starts automatically after init, so you can go straight to `coren`.
          </p>
        </section>

        <hr class="mb-20 border-white/[0.06]" />

        <section class="doc-section mb-20">
          <div class="mb-8 flex items-center gap-3">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-coren-accent/10">
              <Icon name="lucide:settings" class="h-4 w-4 text-coren-accent" />
            </div>
            <h2 class="text-3xl font-bold text-tn-text">Configuration</h2>
          </div>

          <h3 id="coren-config" class="mb-4 scroll-mt-24 text-xl font-semibold text-tn-text">coren config</h3>
          <p class="mb-4 leading-relaxed text-tn-subtext">
            `coren` reads `~/.config/coren/config` as a simple key-value file. Runtime state such as panel position and current AI mode is stored separately in `~/.config/coren/state`.
          </p>
          <div class="overflow-x-auto mb-10">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-white/[0.08]">
                  <th class="px-4 py-3 text-left font-semibold text-tn-subtext">Key</th>
                  <th class="px-4 py-3 text-left font-semibold text-tn-subtext">Default</th>
                  <th class="px-4 py-3 text-left font-semibold text-tn-subtext">Meaning</th>
                </tr>
              </thead>
              <tbody class="text-tn-subtext">
                {corenConfig.map(([key, value, desc]) => (
                  <tr class="border-b border-white/[0.04] last:border-0 hover:bg-white/[0.02]">
                    <td class="px-4 py-3"><code class="text-coren-accent">{key}</code></td>
                    <td class="px-4 py-3 text-tn-muted">{value}</td>
                    <td class="px-4 py-3">{desc}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="terminal-window mb-10">
            <div class="terminal-chrome">
              <span class="h-2.5 w-2.5 rounded-full bg-tn-red/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-tn-yellow/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-tn-green/80"></span>
              <span class="ml-auto text-xs text-tn-muted">~/.config/coren/config</span>
            </div>
<pre class="overflow-x-auto p-4 text-sm font-mono"><code>proxy-url = http://127.0.0.1:4000
workspace = /home/you/Workspace/oceanstack/coren-website
language = es
ai-panel-open = true
ai-panel-width = 90
theme = tokyonight
cursor-style = underline</code></pre>
          </div>

          <h3 id="providers" class="mb-4 scroll-mt-24 text-xl font-semibold text-tn-text">Providers</h3>
          <p class="mb-4 leading-relaxed text-tn-subtext">
            `corend provider add` offers built-in presets and a custom option. The active provider is resolved from MongoDB, not from a flat file.
          </p>
          <div class="card mb-6 p-5">
            <p class="mb-2 text-xs uppercase tracking-[0.2em] text-tn-yellow">API cost warning</p>
            <p class="mb-3 text-sm leading-relaxed text-tn-subtext">
              `ollama` is the safest recommendation when you want `ai-suggest`, inline assist, watch, execute, or debug enabled all the time. Those paths can generate repeated requests, so a paid hosted API can consume credits much faster than expected.
            </p>
            <p class="text-sm leading-relaxed text-tn-subtext">
              `coren-proxi` can also route specific AI services to specific providers. A common split is `assistant -> deepseek` and `suggestions`, `inline`, `commit`, or `review` -> `ollama`, so the cheap local model handles high-frequency requests.
            </p>
          </div>
          <div class="overflow-x-auto mb-10">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-white/[0.08]">
                  <th class="px-4 py-3 text-left font-semibold text-tn-subtext">Name</th>
                  <th class="px-4 py-3 text-left font-semibold text-tn-subtext">Base URL</th>
                  <th class="px-4 py-3 text-left font-semibold text-tn-subtext">Default model</th>
                </tr>
              </thead>
              <tbody class="text-tn-subtext">
                {providers.map(([name, url, model]) => (
                  <tr class="border-b border-white/[0.04] last:border-0 hover:bg-white/[0.02]">
                    <td class="px-4 py-3"><code class="text-coren-accent">{name}</code></td>
                    <td class="px-4 py-3 text-tn-muted">{url}</td>
                    <td class="px-4 py-3">{model}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <p class="mb-3 text-sm font-semibold text-tn-text">Using a preset</p>
          <div class="terminal-window mb-6">
            <div class="terminal-chrome">
              <span class="h-2.5 w-2.5 rounded-full bg-tn-red/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-tn-yellow/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-tn-green/80"></span>
              <span class="ml-auto text-xs text-tn-muted">preset provider</span>
            </div>
            <pre class="overflow-x-auto p-4 text-sm font-mono"><code><span class="text-tn-muted"># register and activate a built-in preset</span>
<span class="text-tn-green">corend provider use deepseek --api-key sk-xxxxxxxxxxxxxxxx</span>

<span class="text-tn-muted"># switch between already-registered providers</span>
<span class="text-tn-green">corend provider use ollama</span></code></pre>
          </div>

          <p class="mb-3 text-sm font-semibold text-tn-text">Routing AI services to different providers</p>
          <p class="mb-4 text-sm leading-relaxed text-tn-subtext">
            Provider routing is per service, not just global. The visible service names are `assistant`, `suggestions`, `inline`, `commit`, and `review`. If one service has no explicit mapping, it falls back to the global active provider.
          </p>
          <div class="terminal-window mb-6">
            <div class="terminal-chrome">
              <span class="h-2.5 w-2.5 rounded-full bg-tn-red/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-tn-yellow/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-tn-green/80"></span>
              <span class="ml-auto text-xs text-tn-muted">ia-service routing</span>
            </div>
            <pre class="overflow-x-auto p-4 text-sm font-mono"><code><span class="text-tn-muted"># inspect current AI service routing</span>
<span class="text-tn-green">corend ia-service list</span>

<span class="text-tn-muted"># route chat to a hosted model</span>
<span class="text-tn-green">corend ia-service use assistant deepseek</span>

<span class="text-tn-muted"># route high-frequency local UX to ollama</span>
<span class="text-tn-green">corend ia-service use suggestions ollama</span>
<span class="text-tn-green">corend ia-service use inline ollama</span>
<span class="text-tn-green">corend ia-service use commit ollama</span>
<span class="text-tn-green">corend ia-service use review ollama</span>

<span class="text-tn-muted"># remove one override and fall back to the global active provider</span>
<span class="text-tn-green">corend ia-service reset commit</span></code></pre>
          </div>

          <p class="mb-3 text-sm font-semibold text-tn-text">Adding a custom provider</p>
          <p class="mb-4 text-sm leading-relaxed text-tn-subtext">
            Any OpenAI-compatible endpoint works. Pass `--base-url` and `--model` to override the defaults, and `--api-key` if the endpoint requires auth.
          </p>
          <div class="terminal-window mb-4">
            <div class="terminal-chrome">
              <span class="h-2.5 w-2.5 rounded-full bg-tn-red/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-tn-yellow/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-tn-green/80"></span>
              <span class="ml-auto text-xs text-tn-muted">custom provider</span>
            </div>
            <pre class="overflow-x-auto p-4 text-sm font-mono"><code><span class="text-tn-muted"># custom OpenAI-compatible endpoint</span>
<span class="text-tn-green">corend provider use custom \</span>
<span class="text-tn-green">  --name "my-provider" \</span>
<span class="text-tn-green">  --base-url https://my-llm-host/v1 \</span>
<span class="text-tn-green">  --model my-model-name \</span>
<span class="text-tn-green">  --api-key sk-xxxxxxxxxxxxxxxx</span></code></pre>
          </div>

          <p class="mb-3 text-sm font-semibold text-tn-text">License status</p>
          <p class="mb-4 text-sm leading-relaxed text-tn-subtext">
            In the AI panel header you will see `plan: free`, `plan: pro`, or `plan: team`. Use `/u status` to print the current effective license state inside the AI panel.
          </p>
          <div class="terminal-window mb-10">
            <div class="terminal-chrome">
              <span class="h-2.5 w-2.5 rounded-full bg-tn-red/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-tn-yellow/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-tn-green/80"></span>
              <span class="ml-auto text-xs text-tn-muted">license status</span>
            </div>
            <pre class="overflow-x-auto p-4 text-sm font-mono"><code><span class="text-tn-muted"># print the current effective license state in the AI panel</span>
<span class="text-tn-green">/u status</span></code></pre>
          </div>
        </section>

        <hr class="mb-20 border-white/[0.06]" />

        <section class="doc-section mb-20">
          <div class="mb-8 flex items-center gap-3">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-coren-accent/10">
              <Icon name="lucide:brain" class="h-4 w-4 text-coren-accent" />
            </div>
            <h2 class="text-3xl font-bold text-tn-text">Runtime</h2>
          </div>

          <h3 id="modes" class="mb-4 scroll-mt-24 text-xl font-semibold text-tn-text">AI modes</h3>
          <div class="grid gap-4 md:grid-cols-2 mb-6">
            <div class="card p-5">
              <h4 class="mb-2 font-semibold text-tn-text">Default</h4>
              <p class="text-sm leading-relaxed text-tn-subtext">General chat mode inside the panel.</p>
            </div>
            <div class="card p-5">
              <h4 class="mb-2 font-semibold text-tn-text">Watch</h4>
              <p class="text-sm leading-relaxed text-tn-subtext">
                After a command finishes, a hint appears in the AI input: <code>Ctrl+E to explain the output of: &lt;cmd&gt;</code>.
                Press <code>Ctrl+E</code> from the terminal or the AI panel to ask for an explanation. Nothing happens automatically.
              </p>
            </div>
            <div class="card p-5">
              <h4 class="mb-2 font-semibold text-tn-text">Execute</h4>
              <p class="text-sm leading-relaxed text-tn-subtext">
                After a command finishes, a hint appears: <code>Ctrl+E to suggest next steps after: &lt;cmd&gt;</code>.
                Press <code>Ctrl+E</code> and optionally type a goal (e.g. <em>deploy to staging</em>) or press Enter to skip.
                coren then suggests the next commands to run using a dedicated stateless API — no conversation history involved.
                You can also type a request directly in the AI input (e.g. <em>list docker volumes</em>) and coren will respond with runnable commands.
              </p>
            </div>
            <div class="card p-5">
              <h4 class="mb-2 font-semibold text-tn-text">Debug</h4>
              <p class="text-sm leading-relaxed text-tn-subtext">
                Monitors command output for errors, warnings, and failure signals. When something worth investigating is detected,
                a hint appears: <code>Ctrl+E to explain the output of: &lt;cmd&gt;</code>. The explanation is part of the conversation,
                so you can follow up with questions.
              </p>
            </div>
          </div>
          <div class="card mb-10 p-5">
            <p class="mb-2 text-xs uppercase tracking-[0.2em] text-tn-yellow">Busy terminal detection</p>
            <p class="text-sm leading-relaxed text-tn-subtext">
              When a command suggested by Execute mode runs while the active pane has a foreground process (e.g. a dev server),
              coren routes it to an idle pane instead of blocking. If no idle pane exists, a new split is opened —
              vertical when the pane is wider than tall, horizontal otherwise. Focus stays on the busy pane so you keep watching the server logs.
            </p>
          </div>

          <h3 id="panel-commands" class="mb-4 scroll-mt-24 text-xl font-semibold text-tn-text">Panel commands</h3>
          <p class="mb-4 leading-relaxed text-tn-subtext">
            Type a slash command in the AI input to trigger panel actions without leaving the keyboard. Commands are organized by namespace and show an interactive overlay as you type.
          </p>

          <p class="mb-3 text-sm font-semibold text-tn-text">/g — git</p>
          <div class="overflow-x-auto mb-6">
            <table class="w-full text-sm">
              <thead><tr class="border-b border-white/[0.08]">
                <th class="px-4 py-3 text-left font-semibold text-tn-subtext">Command</th>
                <th class="px-4 py-3 text-left font-semibold text-tn-subtext">What it does</th>
              </tr></thead>
              <tbody class="text-tn-subtext">
                <tr class="border-b border-white/[0.04] hover:bg-white/[0.02]">
                  <td class="px-4 py-3"><code class="text-coren-accent">/g commit</code></td>
                  <td class="px-4 py-3">Select files to stage or discard, then let the AI generate commit suggestions and a push follow-up.</td>
                </tr>
                <tr class="border-b border-white/[0.04] hover:bg-white/[0.02]">
                  <td class="px-4 py-3"><code class="text-coren-accent">/g review</code></td>
                  <td class="px-4 py-3">Pick a base and head branch from an interactive list, or pass <code>/g review base..head</code> directly. Staged changes are also available as a review target. Use <code>a</code> to analyze all files sequentially for risks, regressions, and missing tests.</td>
                </tr>
                <tr class="border-b border-white/[0.04] hover:bg-white/[0.02]">
                  <td class="px-4 py-3"><code class="text-coren-accent">/g branch</code></td>
                  <td class="px-4 py-3">Ask the AI to suggest a branch name based on staged changes or a description you type in the overlay.</td>
                </tr>
                <tr class="border-b border-white/[0.04] hover:bg-white/[0.02]">
                  <td class="px-4 py-3"><code class="text-coren-accent">/g branch delete</code></td>
                  <td class="px-4 py-3">Pick a local branch from an interactive list and delete it.</td>
                </tr>
                <tr class="border-b border-white/[0.04] hover:bg-white/[0.02]">
                  <td class="px-4 py-3"><code class="text-coren-accent">/g pr</code></td>
                  <td class="px-4 py-3">Pick a local base branch and preview a pull request body before creating it with your detected CLI. Uses a local PR template if one exists, otherwise generates a body using the configured <code>language</code> or the current shell locale.</td>
                </tr>
                <tr class="border-b border-white/[0.04] hover:bg-white/[0.02]">
                  <td class="px-4 py-3"><code class="text-coren-accent">/g sync</code></td>
                  <td class="px-4 py-3">Fetch and rebase the current branch against its upstream in one step.</td>
                </tr>
                <tr class="border-b border-white/[0.04] hover:bg-white/[0.02]">
                  <td class="px-4 py-3"><code class="text-coren-accent">/g conflicts</code></td>
                  <td class="px-4 py-3">Open the conflict navigator. Use <code>Enter</code> or <code>e</code> to open a file in your editor, <code>a</code> to ask AI for an explanation, <code>o</code> for ours, <code>t</code> for theirs, and <code>r</code> to refresh.</td>
                </tr>
                <tr class="border-b border-white/[0.04] hover:bg-white/[0.02]">
                  <td class="px-4 py-3"><code class="text-coren-accent">/g log</code></td>
                  <td class="px-4 py-3">Browse the git log in a scrollable overlay.</td>
                </tr>
                <tr class="border-b border-white/[0.04] hover:bg-white/[0.02]">
                  <td class="px-4 py-3"><code class="text-coren-accent">/g stash</code></td>
                  <td class="px-4 py-3">List stash entries and apply or drop one from an interactive overlay.</td>
                </tr>
                <tr class="border-b border-white/[0.04] last:border-0 hover:bg-white/[0.02]">
                  <td class="px-4 py-3"><code class="text-coren-accent">/g diff</code></td>
                  <td class="px-4 py-3">Show a scrollable diff of unstaged or staged changes.</td>
                </tr>
              </tbody>
            </table>
          </div>

          <p class="mb-3 text-sm font-semibold text-tn-text">/c — conversation</p>
          <div class="overflow-x-auto mb-6">
            <table class="w-full text-sm">
              <thead><tr class="border-b border-white/[0.08]">
                <th class="px-4 py-3 text-left font-semibold text-tn-subtext">Command</th>
                <th class="px-4 py-3 text-left font-semibold text-tn-subtext">What it does</th>
              </tr></thead>
              <tbody class="text-tn-subtext">
                <tr class="border-b border-white/[0.04] hover:bg-white/[0.02]">
                  <td class="px-4 py-3"><code class="text-coren-accent">/c new</code></td>
                  <td class="px-4 py-3">Create a new conversation and clear the panel history.</td>
                </tr>
                <tr class="border-b border-white/[0.04] hover:bg-white/[0.02]">
                  <td class="px-4 py-3"><code class="text-coren-accent">/c history</code></td>
                  <td class="px-4 py-3">Browse and resume recent conversations from the panel.</td>
                </tr>
                <tr class="border-b border-white/[0.04] last:border-0 hover:bg-white/[0.02]">
                  <td class="px-4 py-3"><code class="text-coren-accent">/c bookmarks</code></td>
                  <td class="px-4 py-3">Open saved commands. Use <code>Ctrl+B</code> to bookmark a command from the terminal.</td>
                </tr>
              </tbody>
            </table>
          </div>

          <p class="mb-3 text-sm font-semibold text-tn-text">/p — project memory</p>
          <div class="overflow-x-auto mb-6">
            <table class="w-full text-sm">
              <thead><tr class="border-b border-white/[0.08]">
                <th class="px-4 py-3 text-left font-semibold text-tn-subtext">Command</th>
                <th class="px-4 py-3 text-left font-semibold text-tn-subtext">What it does</th>
              </tr></thead>
              <tbody class="text-tn-subtext">
                <tr class="border-b border-white/[0.04] hover:bg-white/[0.02]">
                  <td class="px-4 py-3"><code class="text-coren-accent">/p context</code></td>
                  <td class="px-4 py-3">Open a full-panel overlay to scroll the project context file. Press <code>e</code> to edit it in your editor.</td>
                </tr>
                <tr class="border-b border-white/[0.04] last:border-0 hover:bg-white/[0.02]">
                  <td class="px-4 py-3"><code class="text-coren-accent">/p condense</code></td>
                  <td class="px-4 py-3">Send the context file to the AI to remove duplicates and compact it, then persist the result to disk.</td>
                </tr>
              </tbody>
            </table>
          </div>

          <p class="mb-3 text-sm font-semibold text-tn-text">/t — terminal</p>
          <div class="overflow-x-auto mb-6">
            <table class="w-full text-sm">
              <thead><tr class="border-b border-white/[0.08]">
                <th class="px-4 py-3 text-left font-semibold text-tn-subtext">Command</th>
                <th class="px-4 py-3 text-left font-semibold text-tn-subtext">What it does</th>
              </tr></thead>
              <tbody class="text-tn-subtext">
                <tr class="border-b border-white/[0.04] hover:bg-white/[0.02]">
                  <td class="px-4 py-3"><code class="text-coren-accent">/t find</code></td>
                  <td class="px-4 py-3">Fuzzy search through shell history and paste the selected entry into the terminal.</td>
                </tr>
                <tr class="border-b border-white/[0.04] last:border-0 hover:bg-white/[0.02]">
                  <td class="px-4 py-3"><code class="text-coren-accent">/t sum</code></td>
                  <td class="px-4 py-3">Summarize the last command output using the AI.</td>
                </tr>
              </tbody>
            </table>
          </div>

          <p class="mb-3 text-sm font-semibold text-tn-text">/u — ui</p>
          <div class="overflow-x-auto mb-10">
            <table class="w-full text-sm">
              <thead><tr class="border-b border-white/[0.08]">
                <th class="px-4 py-3 text-left font-semibold text-tn-subtext">Command</th>
                <th class="px-4 py-3 text-left font-semibold text-tn-subtext">What it does</th>
              </tr></thead>
              <tbody class="text-tn-subtext">
                <tr class="border-b border-white/[0.04] hover:bg-white/[0.02]">
                  <td class="px-4 py-3"><code class="text-coren-accent">/u mode</code></td>
                  <td class="px-4 py-3">Switch the active AI mode: default, watch, execute, or debug.</td>
                </tr>
                <tr class="border-b border-white/[0.04] hover:bg-white/[0.02]">
                  <td class="px-4 py-3"><code class="text-coren-accent">/u panel</code></td>
                  <td class="px-4 py-3">Move the AI panel: bottom, top, left, or right.</td>
                </tr>
                <tr class="border-b border-white/[0.04] hover:bg-white/[0.02]">
                  <td class="px-4 py-3"><code class="text-coren-accent">/u reload</code></td>
                  <td class="px-4 py-3">Reload <code>~/.config/coren/config</code> without restarting, including theme changes.</td>
                </tr>
                <tr class="border-b border-white/[0.04] last:border-0 hover:bg-white/[0.02]">
                  <td class="px-4 py-3"><code class="text-coren-accent">Ctrl+P</code></td>
                  <td class="px-4 py-3">Open the command palette. Groups all commands by namespace into one searchable overlay.</td>
                </tr>
              </tbody>
            </table>
          </div>

          <h3 id="project-memory" class="mb-4 scroll-mt-24 text-xl font-semibold text-tn-text">Project memory</h3>
          <p class="mb-4 leading-relaxed text-tn-subtext">
            Each git repository can have a `.coren/context.md` file that stores project-specific notes. coren injects this file into AI conversations, inline assist hints, and command completions automatically whenever the terminal is inside that repository.
          </p>
          <div class="grid gap-4 md:grid-cols-3 mb-6">
            <div class="card p-5">
              <h4 class="mb-2 font-semibold text-tn-text">Save a note</h4>
              <p class="text-sm leading-relaxed text-tn-subtext">Type <code>remember that ...</code> or <code>recuerda que ...</code> in the AI input. The note is saved to <code>.coren/context.md</code> with automatic deduplication.</p>
            </div>
            <div class="card p-5">
              <h4 class="mb-2 font-semibold text-tn-text">/p context</h4>
              <p class="text-sm leading-relaxed text-tn-subtext">Open a full-panel overlay to scroll the current context file. Press <code>e</code> to edit it in your editor and <code>Esc</code> to close.</p>
            </div>
            <div class="card p-5">
              <h4 class="mb-2 font-semibold text-tn-text">/p condense</h4>
              <p class="text-sm leading-relaxed text-tn-subtext">Send the context file to the AI to remove duplicates and compact it, then persist the result back to disk. Also runs automatically when the proxy compacts a long conversation.</p>
            </div>
          </div>
          <div class="card mb-6 p-5">
            <p class="mb-2 text-xs uppercase tracking-[0.2em] text-tn-yellow">File location</p>
            <p class="mb-3 text-sm leading-relaxed text-tn-subtext">
              Context is stored per-project in <code>.coren/context.md</code> at the git root. The <code>.coren/</code> directory is created automatically on first save. Add it to <code>.gitignore</code> if you want to keep it local.
            </p>
            <pre class="overflow-x-auto rounded-xl border border-white/[0.08] bg-tn-night/70 p-4 text-sm font-mono"><code><span class="text-tn-muted"># example .coren/context.md</span>
<span class="text-tn-green"># Project Context</span>

<span class="text-tn-muted"><!-- mem:1a2b3c4d --></span>
<span class="text-tn-text">**[General — 2025-05-01]** The API uses JWT auth, tokens expire in 15 minutes.</span>

<span class="text-tn-muted"><!-- mem:5e6f7a8b --></span>
<span class="text-tn-text">**[Comandos — 2025-05-02]** make dev starts the local stack on port 8080.</span></code></pre>
          </div>
          <p class="mb-10 text-sm leading-relaxed text-tn-subtext">
            Notes are auto-categorized as <code>Variables</code>, <code>Comandos</code>, <code>Git</code>, or <code>General</code> based on content patterns. Duplicate detection uses keyword overlap — entries with ≥ 45 % shared keywords are discarded silently.
          </p>

          <h3 id="shortcuts" class="mb-4 scroll-mt-24 text-xl font-semibold text-tn-text">Keyboard</h3>
          <div class="shortcut-table mb-10">
            <div class="shortcut-row">
              <kbd class="key">Ctrl</kbd><span class="key-sep">+</span><kbd class="key">O</kbd>
              <span class="text-tn-subtext">Open or close the AI panel.</span>
            </div>
            <div class="shortcut-row">
              <kbd class="key">Ctrl</kbd><span class="key-sep">+</span><kbd class="key">G</kbd>
              <span class="text-tn-subtext">Toggle focus between the AI input and the terminal (only when the panel is open).</span>
            </div>
            <div class="shortcut-row">
              <kbd class="key">Ctrl</kbd><span class="key-sep">+</span><kbd class="key">P</kbd>
              <span class="text-tn-subtext">Open the command palette for review, commit, branch sync, shell history, bookmarks, AI mode switches, panel controls, and conversation actions.</span>
            </div>
            <div class="shortcut-row">
              <kbd class="key">Ctrl</kbd><span class="key-sep">+</span><kbd class="key">Q</kbd>
              <span class="text-tn-subtext">Quit or move back to the terminal depending on state.</span>
            </div>
            <div class="shortcut-row">
              <kbd class="key">Esc</kbd>
              <span class="text-tn-subtext">Return to terminal focus from the AI panel.</span>
            </div>
            <div class="shortcut-row">
              <kbd class="key">Ctrl</kbd><span class="key-sep">+</span><kbd class="key">E</kbd>
              <span class="text-tn-subtext">Explain the last command output (Watch/Debug) or suggest next steps (Execute). Works from both the terminal and the AI panel without changing focus.</span>
            </div>
            <div class="shortcut-row">
              <kbd class="key">Tab</kbd>
              <span class="text-tn-subtext">Accept inline AI suggestion.</span>
            </div>
            <div class="shortcut-row">
              <kbd class="key">Alt</kbd><span class="key-sep">+</span><kbd class="key">←</kbd>/<kbd class="key">→</kbd>/<kbd class="key">↑</kbd>/<kbd class="key">↓</kbd>
              <span class="text-tn-subtext">Move the AI panel around the terminal.</span>
            </div>
            <div class="shortcut-row">
              <kbd class="key">Alt</kbd><span class="key-sep">+</span><kbd class="key">=</kbd>/<kbd class="key">-</kbd>
              <span class="text-tn-subtext">Grow or shrink the AI panel. Size is saved to state and restored on next launch. Capped at 75% of the terminal dimension.</span>
            </div>
          </div>
          <div class="card mb-10 p-5">
            <p class="mb-2 text-sm font-semibold text-tn-text">Review and conflicts</p>
            <ul class="space-y-2 text-sm leading-relaxed text-tn-subtext">
              <li><span class="text-coren-accent">›</span> In review mode, <code>Tab</code> switches between the diff and the AI review. Use <code>a</code> to analyze all files, <code>r</code> for the global summary, and <code>n</code>/<code>p</code> to jump between files with findings.</li>
              <li><span class="text-coren-accent">›</span> The review header shows <code>review: &lt;provider&gt;</code>, keeps a short <code>findings x/y</code> counter, and the file list uses <code>✓</code>, <code>!</code>, <code>!2</code>, and <code>!3</code> markers.</li>
              <li><span class="text-coren-accent">›</span> In conflicts mode, <code>a</code> asks AI to explain the selected conflict, <code>o</code> applies <code>ours</code>, <code>t</code> applies <code>theirs</code>, and when no conflicts remain coren shows the next git command to continue.</li>
            </ul>
          </div>

          <h3 id="service" class="mb-4 scroll-mt-24 text-xl font-semibold text-tn-text">User service</h3>
          <p class="mb-4 leading-relaxed text-tn-subtext">
            `corend service install` writes a user-level systemd unit in `~/.config/systemd/user/coren-proxi.service` and points it at the `coren-proxi` binary.
          </p>
          <div class="terminal-window">
            <div class="terminal-chrome">
              <span class="h-2.5 w-2.5 rounded-full bg-tn-red/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-tn-yellow/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-tn-green/80"></span>
              <span class="ml-auto text-xs text-tn-muted">service</span>
            </div>
            <pre class="overflow-x-auto p-4 text-sm font-mono"><code><span class="text-tn-green">cd ../coren-proxi</span>
<span class="text-tn-green">corend service install</span>
<span class="text-tn-green">corend service start</span>
<span class="text-tn-green">corend service status</span></code></pre>
          </div>
        </section>

        <hr class="mb-20 border-white/[0.06]" />

        <section class="doc-section">
          <div class="mb-8 flex items-center gap-3">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-coren-accent/10">
              <Icon name="lucide:wrench" class="h-4 w-4 text-coren-accent" />
            </div>
            <h2 class="text-3xl font-bold text-tn-text">Troubleshooting</h2>
          </div>

          <h3 id="port-mismatch" class="mb-4 scroll-mt-24 text-xl font-semibold text-tn-text">Port mismatch</h3>
          <div class="card mb-8 p-5">
            <p class="mb-3 text-sm leading-relaxed text-tn-subtext">
              If the AI panel cannot reach the proxy, verify that `coren-proxi` is running and that your local config points at the expected proxy URL.
            </p>
            <pre class="overflow-x-auto rounded-xl border border-white/[0.08] bg-tn-night/70 p-4 text-sm font-mono"><code><span class="text-tn-green">corend service status</span>
<span class="text-tn-green">corend service logs</span></code></pre>
          </div>

          <h3 id="mongo" class="mb-4 scroll-mt-24 text-xl font-semibold text-tn-text">MongoDB</h3>
          <div class="terminal-window mb-6">
            <div class="terminal-chrome">
              <span class="h-2.5 w-2.5 rounded-full bg-tn-red/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-tn-yellow/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-tn-green/80"></span>
              <span class="ml-auto text-xs text-tn-muted">db</span>
            </div>
            <pre class="overflow-x-auto p-4 text-sm font-mono"><code><span class="text-tn-green">corend db status</span>
<span class="text-tn-green">corend db logs -f</span></code></pre>
          </div>
          <div class="card mb-8 p-5">
            <p class="mb-2 text-xs uppercase tracking-[0.2em] text-tn-yellow">Changing the MongoDB port</p>
            <p class="mb-3 text-sm leading-relaxed text-tn-subtext">
              The port chosen during `corend init` is stored in <code>~/.config/coren-proxi/.env</code> as <code>DB_PORT</code> and <code>DATABASE_URI</code>. To change it, edit that file and restart both the container and the proxy service.
            </p>
            <pre class="overflow-x-auto rounded-xl border border-white/[0.08] bg-tn-night/70 p-4 text-sm font-mono"><code><span class="text-tn-muted"># edit the port in the env file</span>
<span class="text-tn-green">$EDITOR ~/.config/coren-proxi/.env</span>

<span class="text-tn-muted"># recreate the container and restart the proxy</span>
<span class="text-tn-green">corend db stop</span>
<span class="text-tn-green">corend db start</span>
<span class="text-tn-green">systemctl --user restart coren-proxi</span></code></pre>
          </div>

          <h3 id="workspace" class="mb-4 scroll-mt-24 text-xl font-semibold text-tn-text">Workspace export</h3>
          <div class="card p-5">
            <p class="mb-3 text-sm leading-relaxed text-tn-subtext">
              `corend shell init zsh --workspace /path/to/repo` or `corend shell init bash --workspace /path/to/repo` updates your shell rc and writes `export COREN_WORKSPACE="..."`.
            </p>
            <p class="text-sm leading-relaxed text-tn-subtext">
              If `coren` opens in the right directory but AI context looks wrong, confirm that variable or set `workspace = /path/to/repo` in `~/.config/coren/config`.
            </p>
          </div>
        </section>
      </div>
    </div>
  </div>
</Layout>
